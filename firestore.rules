rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Client Agent Documents ─────────────────────────────────────────────
    // Only authenticated users whose email is in the document's allowedEmails
    // array can read their own agent record. No public writes allowed.
    match /agents/{agentId} {
      allow read: if request.auth != null
                  && request.auth.token.email in resource.data.allowedEmails;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
